<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMinhasCompras.Views.Inicial">
    
    <VerticalStackLayout
        Padding="30"
        Spacing="25"
        VerticalOptions="Center">
        <Label 
            Text="Seja Bem-vindo! O que deseja?"
            TextColor="Chocolate"
            FontSize="25"
            HorizontalTextAlignment="Center"
            FontAttributes="Bold" />
        
        <Button Text="Cadastrar novo produto" Clicked="OnCadastrarClicked"
            BackgroundColor="Chocolate"
            TextColor="White"
            CornerRadius="25"
            FontSize="16"
            FontAttributes="Bold"
            HeightRequest="55"/>

        <Button Text="Listar produtos" Clicked="OnListarClicked"
            BackgroundColor="Chocolate"
            TextColor="White"
            CornerRadius="25"
            FontSize="16"
            FontAttributes="Bold"
            HeightRequest="55"/>

        <Button Text="Editar produto" Clicked="OnEditarClicked"
            BackgroundColor="Chocolate"
            TextColor="White"
            CornerRadius="25"
            FontSize="16"
            FontAttributes="Bold"
            HeightRequest="55"/>
        
    </VerticalStackLayout>
</ContentPage>