<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">
    <!-- Navegação -->
    <ContentPage.ToolbarItems>
        <!-- Somar o total da lista de compras -->
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1"/>
        <!-- Adicionar produtos -->
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked"/>

    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center"/>
            </Style>
            
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <StackLayout>
        
        <!-- Mecanismo de busca -->
        <SearchBar x:Name="txt_search" 
                   Margin="-15, 0, 0, 0"
                   Placeholder="Digite para buscar produtos"
                   TextChanged="txt_search_TextChanged"/>

        <Frame Padding="0" Margin="10"  VerticalOptions="FillAndExpand"> 
        <!-- Exibir lista dos dados (coleção de itens) e regarregar por meio do refresh -->
        <ListView x:Name="lst_produtos" ItemSelected="lst_produtos_ItemSelected"
                  IsPullToRefreshEnabled="True"
                  Refreshing="lst_produtos_Refreshing"
                  >

            <!-- Título das colunas -->
            <ListView.Header>
                <!-- Dados por coluna -->
                <Grid ColumnDefinitions="30, 100, 80, 50, 90"
                      BackgroundColor="{StaticResource Gray100}"
                      >
                    
                    <!-- Texto das informações na coluna (grid) -->
                        <Label Grid.Column="0" Text="ID" Padding="5" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold"/>
                        <Label Grid.Column="2" Text="Preço" FontAttributes="Bold"/>
                        <Label Grid.Column="3" Text="Quantidade" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Total" FontAttributes="Bold"/>
                    
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate> 
                    
                    <!-- Ver conteúdo dentro da listview -->
                    <ViewCell>

                        <!-- Interação do usuário com item (segura ou desliza): Aparece a opção remover -->
                        <ViewCell.ContextActions>
                            <MenuItem Text="Remover" Clicked="MenuItem_Clicked"/>
                        </ViewCell.ContextActions>

                        <Grid ColumnDefinitions="30, 100, 80, 50, 90">
                            <Label Grid.Column="0" Text="{Binding Id}" Padding="5"/>
                            <Label Grid.Column="1" Text="{Binding Descricao}"/>
                            <!--- Uso do R$-->
                            <Label Grid.Column="2" Text="{Binding Preco, StringFormat='{}{0:c}'}"/>
                            <Label Grid.Column="3" Text="{Binding Quantidade}"/>
                            <Label Grid.Column="4" Text="{Binding Total, StringFormat='{}{0:c}'}"/>
                        </Grid>

                    </ViewCell>
                        
                </DataTemplate>
            </ListView.ItemTemplate>
            
        </ListView>
        </Frame>
    </StackLayout>
</ContentPage>